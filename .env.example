# ─── Database ───
DATABASE_URL=postgres://hypespace:hypespace@localhost:5433/hypespace

# ─── Server ───
API_SERVER_PORT=4000
VITE_PORT=5173
API_PROXY_TARGET=http://localhost:4000
NODE_ENV=development

# ─── Session ───
# Required in production; defaults to a dev-only secret when unset.
# SESSION_SECRET=change-me-to-a-long-random-string

# ─── CORS ───
# Comma-separated list of origins allowed to call the API with credentials.
# In development the server already allows http://localhost:5173 and the
# Capacitor native origins (capacitor://localhost, http://localhost,
# https://localhost) by default. Use this to add extra origins.
# In production, set this explicitly — e.g.
#   ALLOWED_ORIGINS=https://app.hypespace.app,capacitor://localhost,https://localhost
ALLOWED_ORIGINS=

# ─── Web client API base URL ───
# API base URL baked into the web bundle at build time.
# Leave empty for same-origin deployments (uses relative /api paths — Vite dev
# proxy in development, reverse proxy in production).
# Set to a full origin (e.g. https://api.hypespace.app) for Capacitor/native
# builds where there is no proxy in front of the web view.
VITE_API_BASE_URL=

# ─── AI providers (optional) ───
# Set your Anthropic API key to enable AI campaign generation
# Get one at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
